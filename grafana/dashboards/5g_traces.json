    {
      "id": 11,
      "title": "Recent 5G Packets \u2014 click Trace ID to inspect",
      "type": "table",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "options": {
        "footer": {
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Start time"
          }
        ],
        "collapseAll": true
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "refId": "A",
          "query": "{span.source=\"capture\"} | select(span.src_nf, span.dst_nf, span.protocol, span.procedure, span.nas_message, span.imsi, span.generation, span.message_direction)",
          "limit": 50,
          "tableType": "traces",
          "spss": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
