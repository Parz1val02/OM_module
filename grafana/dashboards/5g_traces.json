      },
      "description": "Live table of completed traces from packet capture. Click any row to open the full per-message waterfall in Tempo. Use the IMSI Filter variable above to narrow to a specific subscriber.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          },
          "links": [
            {
              "title": "Open waterfall in Tempo",
              "url": "/explore?left=%7B%22datasource%22%3A%22tempo%22%2C%22queries%22%3A%5B%7B%22query%22%3A%22${__data.fields.trace_id}%22%2C%22queryType%22%3A%22traceql%22%2C%22refId%22%3A%22A%22%7D%5D%7D&orgId=1",
              "targetBlank": false
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "trace_id"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Trace ID"
              },
              {
                "id": "custom.width",
                "value": 260
              }
